{
  "name": "sift-kernel",
  "version": "0.1.0",
  "description": "Forensic Evidence Operating System — MCP server for SIFT Workstation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sift-kernel": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run tests/property",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && echo 'Types OK'"
  },
  "keywords": [
    "mcp",
    "forensics",
    "sift",
    "dfir",
    "incident-response"
  ],
  "author": "sathvik",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "11.10.0",
    "exponential-backoff": "3.1.3",
    "nanoid": "5.1.0",
    "neverthrow": "8.2.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.10.0",
    "fast-check": "4.8.0",
    "tsx": "4.19.0",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
